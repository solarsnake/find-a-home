# ── Twilio SMS ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543

# ── SendGrid Email ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=you@yourdomain.com

# ── Scraping Behaviour ───────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
# Seconds to wait between page loads (randomized within range)
SCRAPE_DELAY_MIN=2.5
SCRAPE_DELAY_MAX=6.0

# ── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=data
SEEN_LISTINGS_FILE=data/seen_listings.json

# ── Financial Defaults (override per-profile in search_profiles.json) ────────
DEFAULT_INTEREST_RATE=0.065
DEFAULT_DOWN_PAYMENT=100000
DEFAULT_MAX_PITI=4500
DEFAULT_INSURANCE=200

# ── Web API (future) ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
